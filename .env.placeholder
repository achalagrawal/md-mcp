# Agentset credentials for semantic_search (https://agentset.ai)
# For local stdio usage: copy this file to .env and fill in real values
# (the build copies .env into build/). For Docker/Coolify deployments,
# leave .env alone and inject these as runtime environment variables instead.
AGENTSET_API_KEY=your_api_key_here
AGENTSET_NAMESPACE_ID=your_namespace_id_here
# Optional: only needed if you use Agentset multi-tenancy
AGENTSET_TENANT_ID=your_tenant_id_here
